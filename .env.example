DJANGO_ENV=local
DJANGO_SECRET_KEY=replace-with-very-long-secure-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,foresta.aguasyservicioslaz.cl,api-foresta.aguasyservicioslaz.cl

TIME_ZONE=America/Santiago

DB_ENGINE=sqlite
# DB_ENGINE=postgres
# DB_NAME=parcelas
# DB_USER=postgres
# DB_PASSWORD=replace-db-password
# DB_HOST=localhost
# DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://foresta.aguasyservicioslaz.cl
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://foresta.aguasyservicioslaz.cl

JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
JWT_SIGNING_KEY=replace-with-at-least-32-random-bytes
API_PAGE_SIZE=25
LOG_LEVEL=INFO

VITE_APP_BASE_NAME=/
VITE_API_BASE_URL=https://api-foresta.aguasyservicioslaz.cl/api/v1

